# ── Django ─────────────────────────────────────────────
DJANGO_SECRET_KEY=your-very-secret-key-change-this
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ────────────────────────────────────────────
DB_NAME=agricare_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Set to True to use SQLite instead of Postgres (dev only)
USE_SQLITE=False

# ── Gmail SMTP ──────────────────────────────────────────
EMAIL_HOST_USER=my_email@gmail.com
# Use a Gmail App Password (not your real password)
# Google Account → Security → 2-Step Verification → App Passwords
EMAIL_HOST_PASSWORD=my_gmail_app_password

# ── OTP ─────────────────────────────────────────────────
OTP_EXPIRY_MINUTES=10

# ── Channels (WebSocket) ─────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# Set True to skip Redis for local dev (chat still works, just not multi-process)
USE_IN_MEMORY_CHANNELS=False

# ── Payment Gateways ─────────────────────────────────────
PAYMENT_SANDBOX=True
# JazzCash (get from sandbox.jazzcash.com.pk)
JAZZCASH_MERCHANT_ID=
JAZZCASH_PASSWORD=
JAZZCASH_INTEGRITY_SALT=
# Easypaisa (get from easypay.easypaisa.com.pk)
EASYPAISA_STORE_ID=
EASYPAISA_ACCOUNT_NO=
EASYPAISA_HASH_KEY=
